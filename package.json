{
  "name": "e-pos-x",
  "version": "1.0.0",
  "description": "E POS X - Premium Desktop POS System for Studios",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:web": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "server": "node server/index.js",
    "dev:server": "concurrently \"npm run server\" \"vite\"",
    "serve:all": "npm run build:web && npm run server"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "firebase": "^12.14.0",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "recharts": "^2.15.0",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.eposx.app",
    "productName": "E POS X",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database.js"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
